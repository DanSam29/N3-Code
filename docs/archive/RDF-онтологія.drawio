<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36" version="29.5.6">
  <diagram name="Страница-1" id="7lOV57G13fhRDGMRZ1cR">
    <mxGraphModel dx="2194" dy="1195" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml Schedule_RDF_Ontology\n\nskinparam backgroundColor #FAFAFA\nskinparam classBorderColor #2C5F8A\nskinparam classBackgroundColor #EBF3FB\nskinparam classHeaderBackgroundColor #2C5F8A\nskinparam classHeaderFontColor #FFFFFF\nskinparam classFontSize 12\nskinparam ArrowColor #2C5F8A\nskinparam ArrowFontSize 11\nskinparam NoteBackgroundColor #FFF9E6\nskinparam NoteBorderColor #D4A017\n\nclass \&quot;sched:ScheduleDocument\&quot; as ScheduleDocument &lt;&lt;owl:Class&gt;&gt; {\n  + sched:documentId : xsd:integer\n  + sched:filename : xsd:string\n  + sched:uploadDate : xsd:dateTime\n  + sched:filePath : xsd:string\n  + sched:status : xsd:string\n  + sched:rawText : xsd:string\n  + sched:processedAt : xsd:dateTime\n  ~ sched:op_loadFromFile()\n  ~ sched:op_extractText()\n  ~ sched:op_getStatus()\n}\n\nclass \&quot;sched:ScheduleParser\&quot; as ScheduleParser &lt;&lt;owl:Class&gt;&gt; {\n  + sched:modelName : xsd:string\n  + sched:parsingPrompt : xsd:string\n  ~ sched:op_parseDocument()\n  ~ sched:op_extractScheduleStructure()\n  ~ sched:op_identifyGroups()\n  ~ sched:op_identifyLessons()\n  ~ sched:op_validateParsingResult()\n}\n\nclass \&quot;sched:Lesson\&quot; as Lesson &lt;&lt;owl:Class&gt;&gt; {\n  + sched:lessonId : xsd:integer\n  + sched:groupName : xsd:string\n  + sched:dayOfWeek : xsd:string\n  + sched:weekType : xsd:string\n  + sched:timeStart : xsd:string\n  + sched:timeEnd : xsd:string\n  + sched:subject : xsd:string\n  + sched:lessonType : xsd:string\n  + sched:teacher : xsd:string\n  + sched:classroom : xsd:string\n  + sched:isElective : xsd:boolean\n  + sched:subgroups : xsd:string [0..*]\n  ~ sched:op_toDict()\n  ~ sched:op_toJson()\n  ~ sched:op_matchesQuery()\n}\n\nclass \&quot;sched:Group\&quot; as Group &lt;&lt;owl:Class&gt;&gt; {\n  + sched:name : xsd:string  [owl:InverseFunctionalProperty]\n  + sched:faculty : xsd:string\n  + sched:course : xsd:integer\n  + sched:specialty : xsd:string\n  ~ sched:op_getLessonsByDay()\n  ~ sched:op_getLessonsByWeekType()\n  ~ sched:op_getScheduleJson()\n}\n\nclass \&quot;sched:ScheduleQuery\&quot; as ScheduleQuery &lt;&lt;owl:Class&gt;&gt; {\n  + sched:queryGroupName : xsd:string [0..1]\n  + sched:queryDayOfWeek : xsd:string [0..1]\n  + sched:queryWeekType : xsd:string [0..1]\n  + sched:queryTeacher : xsd:string [0..1]\n  + sched:querySubject : xsd:string [0..1]\n  + sched:queryClassroom : xsd:string [0..1]\n  + sched:queryDate : xsd:dateTime [0..1]\n  ~ sched:op_fromNaturalLanguage()\n  ~ sched:op_toFilterDict()\n}\n\nclass \&quot;sched:ScheduleDatabase\&quot; as ScheduleDatabase &lt;&lt;owl:Class&gt;&gt; {\n  + sched:dbPath : xsd:string\n  ~ sched:op_saveLessons()\n  ~ sched:op_getLessonsByQuery()\n  ~ sched:op_getGroupSchedule()\n  ~ sched:op_updateLesson()\n  ~ sched:op_deleteLesson()\n  ~ sched:op_saveGroup()\n}\n\nclass \&quot;sched:LLMClient\&quot; as LLMClient &lt;&lt;owl:Class&gt;&gt; {\n  + sched:apiKey : xsd:string\n  + sched:model : xsd:string\n  + sched:temperature : xsd:float\n  ~ sched:op_analyzeText()\n  ~ sched:op_extractStructuredData()\n  ~ sched:op_answerQuestion()\n}\n\nScheduleDocument --&gt; ScheduleParser : sched:usesParser\\n[owl:ObjectProperty]\\n[owl:FunctionalProperty]\n\nScheduleParser *--&gt; LLMClient : sched:hasLLMClient\\n[owl:ObjectProperty]\\n[owl:FunctionalProperty]\n\nScheduleParser ..&gt; Lesson : sched:createsLesson\\n[owl:ObjectProperty]\\n[1..*]\n\nScheduleDocument \&quot;1\&quot; --&gt; \&quot;1..*\&quot; Lesson : sched:containsLesson\\n[owl:ObjectProperty]&lt;/size&gt;\n\nGroup \&quot;1\&quot; --&gt; \&quot;1..*\&quot; Lesson : sched:hasLesson\\n[owl:ObjectProperty]\n\nScheduleQuery \&quot;*\&quot; ..&gt; \&quot;1\&quot; ScheduleDatabase : sched:usesDatabase\\n[owl:ObjectProperty]\n\nScheduleDatabase o--&gt; \&quot;1..*\&quot; Lesson : sched:storesLesson\\n[owl:ObjectProperty]\n\nScheduleDatabase o--&gt; \&quot;1..*\&quot; Group : sched:storesGroup\\n[owl:ObjectProperty]\n\nLesson ..&gt; ScheduleDocument : sched:belongsToDocument\\n[owl:inverseOf sched:containsLesson]\nLesson ..&gt; Group : sched:belongsToGroup\\n[owl:inverseOf sched:hasLesson]\n\nnote top of ScheduleDocument\n  &lt;b&gt;owl:Class&lt;/b&gt;\n  rdfs:label \&quot;Документ розкладу\&quot;@uk\n  rdfs:comment \&quot;Завантажений файл з\n  розкладом занять\&quot;@uk\n  sched:status ∈ {\n    \&quot;pending\&quot;, \&quot;processing\&quot;,\n    \&quot;completed\&quot;, \&quot;error\&quot;\n  }\nend note\n\nnote top of Lesson\n  &lt;b&gt;owl:Class&lt;/b&gt;\n  rdfs:label \&quot;Пара (заняття)\&quot;@uk\n  sched:weekType ∈ {\n    \&quot;numerator\&quot;,\n    \&quot;denominator\&quot;,\n    \&quot;all\&quot;\n  }\n  sched:lessonType ∈ {\n    \&quot;лекція\&quot;, \&quot;практика\&quot;,\n    \&quot;лабораторна\&quot;\n  }\nend note\n\nnote top of LLMClient\n  &lt;b&gt;owl:Class&lt;/b&gt;\n  rdfs:label \&quot;LLM Клієнт\&quot;@uk\n  rdfs:comment \&quot;Абстракція для\n  роботи з LLM API\&quot;@uk\n  sched:temperature ∈ [0.0 .. 1.0]\nend note\n\nnote bottom of Group\n  &lt;b&gt;owl:Class&lt;/b&gt;\n  rdfs:label \&quot;Академічна група\&quot;@uk\n  sched:name → owl:InverseFunctionalProperty\n  (унікальний ідентифікатор групи)\nend note\n\nnote right of ScheduleQuery\n  &lt;b&gt;owl:Class&lt;/b&gt;\n  rdfs:label \&quot;Запит користувача\&quot;@uk\n  Усі атрибути є owl:Optional\n  (мінімальна кратність = 0)\nend note\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="uX-VpJLUiTEJa6XRHyRA-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1589" width="1161" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
